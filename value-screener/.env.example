# value-screener LLM 环境变量配置模板
#
# 用法：复制本文件为 .env 并填入真实值
#   cp .env.example .env
#   vim .env
# .env 不会进 git（已在 .gitignore），本文件 .env.example 进 git 但只含占位符。
#
# compose 通过 ${VAR:?err} 读取这些变量；缺失任一必填项时
# docker compose run 会在容器启动前 fail-fast 报错。

# === 必填：LLM API 凭据 ===
# L2 (scout) 与 L3 (council) 共用的 OpenAI 兼容 API
LLM_API_KEY=
LLM_API_BASE=https://api.openai.com/v1

# === 必填：L2 轻量推理模型 ===
# 用于 scout 批量初筛（~200 只，成本闸门，AD-03）
LLM_MODEL=gpt-4o-mini

# === 必填：L3 重度推理模型（R1-3 辩论）===
LLM_MODEL_HEAVY=

# === 必填：L3 中度推理模型（R4 收敛）===
LLM_MODEL_MODERATE=

# === 可选：代理配置 ===
# 容器内访问 akshare / LLM API 需要走代理时取消注释
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
